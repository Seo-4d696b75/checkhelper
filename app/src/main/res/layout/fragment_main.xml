<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:custom="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="105dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:text="最寄駅の情報"
                        android:textColor="@color/colorPrimaryDark"
                        android:textSize="18sp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/stationWaitMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/textDefault"
                            android:padding="5dp"
                            android:text="@string/message_wait"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:id="@+id/stationSearchMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <ProgressBar
                                style="?android:attr/progressBarStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="5dp"
                                android:textColor="@color/textDefault"
                                android:text="@string/message_search_radar"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/containerStation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="visible">
                            <jp.ac.u_tokyo.t.seo.station.app.StationNameView
                                android:id="@+id/stationNameMain"
                                android:layout_marginStart="8dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                custom:nameTextColor="@color/colorBlack"
                                custom:nameTextSize="22sp"
                                custom:phoneticTextColor="@color/colorBlack"
                                custom:phoneticTextSize="12sp"/>

                            <android.support.v4.widget.Space
                                android:layout_width="1dp"
                                android:layout_height="7dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_location"/>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="4dp"
                                    android:paddingEnd="0dp">


                                    <TextView
                                        android:id="@+id/textStationPrefecture"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/textDefault"
                                        android:text=""/>

                                    <TextView
                                        android:id="@+id/textDistance"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/textDefault"
                                        android:text=""/>


                                </LinearLayout>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="1dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/station"/>

                                <jp.ac.u_tokyo.t.seo.customview.HorizontalListView
                                    android:paddingStart="4dp"
                                    android:paddingEnd="0dp"
                                    android:id="@+id/listStationLines"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"/>
                            </LinearLayout>

                        </LinearLayout>
                    </FrameLayout>

                </LinearLayout>

                <RelativeLayout
                    android:layout_alignParentEnd="true"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="28dp">

                    <jp.ac.u_tokyo.t.seo.station.app.AnimationView
                        android:id="@+id/animationView"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_alignParentEnd="true"/>


                </RelativeLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:padding="2dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_line_select"/>


                <jp.ac.u_tokyo.t.seo.customview.ExpandableTextView
                    android:id="@+id/textSelectedLine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    custom:maxWidth="100dp"
                    android:text="@string/line_none"/>
            </LinearLayout>

        </RelativeLayout>

            <RelativeLayout
                android:id="@+id/containerSubFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="50dp"/>

    </LinearLayout>

    <View
        android:visibility="gone"
        android:background="@color/menu_button_back"
        android:id="@+id/floatButtonScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <RelativeLayout
        android:id="@+id/floatButtonContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:layout_alignParentBottom="true">

        <Button
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:id="@+id/buttonTimer"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button_timer"
            android:visibility="invisible"/>

        <Button
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:id="@+id/buttonTimerFixed"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button_fixed"
            android:visibility="invisible"/>

        <Button
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="0dp"
            android:id="@+id/buttonLineSelect"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button_line_select"
            android:visibility="invisible"/>

        <Button
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="0dp"
            android:id="@+id/buttonLineCancel"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button_line_cancel"
            android:visibility="invisible"/>

        <Button
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="0dp"
            android:id="@+id/buttonLinePredict"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/button_position"
            android:visibility="invisible"/>

        <Button
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="15dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:id="@+id/buttonMap"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:visibility="invisible"
            android:background="@drawable/button_map"/>

        <Button
            android:layout_marginEnd="82dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:id="@+id/buttonMenu"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/button_menu"
            android:visibility="visible"/>

        <Button
            android:layout_marginEnd="134dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:id="@+id/buttonFinish"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/button_exit"
            android:visibility="visible"/>


        <ToggleButton
            android:id="@+id/toggleStart"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/button_start"
            android:checked="false"
            android:textOff=""
            android:textOn=""/>

    </RelativeLayout>


</RelativeLayout>
